# ---------------------------------------------------------------------------
# Copy to .env and fill in. EVERYTHING here has a safe default, so the agent
# runs end-to-end with NO configuration (it falls back to the deterministic
# mock LLM + in-memory matcher). Set a real provider to use a real LLM.
# ---------------------------------------------------------------------------

# --- LLM provider: "mock" (default, no key needed) | "openai" | "anthropic" ---
LLM_PROVIDER=mock

# Only needed if LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Only needed if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# --- Data layer: "memory" (default) | "postgres" ---
MATCHER_BACKEND=memory

# Only used if MATCHER_BACKEND=postgres. Matches docker-compose.yml defaults.
DATABASE_URL=postgresql://agentmira:agentmira@localhost:5432/agentmira

# Path to the MLS CSV (used by the loader and by the in-memory matcher)
MLS_CSV_PATH=data/miami_mls_listings.csv
